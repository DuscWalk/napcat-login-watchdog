[Unit]
Description=NapCat login watchdog QR click webhook
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/napcat-login-watchdog
EnvironmentFile=/opt/napcat-login-watchdog/.env
ExecStart=/opt/napcat-login-watchdog/.venv/bin/napcat-login-watchdog serve-click-webhook
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

